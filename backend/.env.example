DATABASE_URL="postgresql://user:password@localhost:5432/havenflow?schema=public"
JWT_SECRET="your-secret-key-change-in-production-min-32-chars"
PORT=3001
NODE_ENV=development

# Email verification (Resend: https://resend.com). Required in production to send verification mail.
# RESEND_API_KEY="re_Zf7zXeQ9_G27qi69CPYykSdGYaTqrXxa9"
RESEND_API_KEY=""
EMAIL_FROM="Haven Check <noreply@havencheck.vercel.app>"
# Base URL of the web app (used in verification links)
WEB_APP_URL="http://localhost:3000"

# Production: comma-separated browser origins allowed by CORS (e.g. https://portal.example.com).
# If unset in production, browser clients are blocked until you set this. Mobile/curl have no Origin.
# CORS_ORIGIN="https://your-web-portal.example.com"

# Set to 1 when running behind a reverse proxy / load balancer (correct client IP + rate limits).
# TRUST_PROXY=1
